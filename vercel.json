{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://2026-techeer-a.duckdns.org/api/:path*" },
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ]
}
